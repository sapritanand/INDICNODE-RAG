# Required — get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional overrides (defaults shown)
# Any model slug from https://openrouter.ai/models works here
GENERATION_MODEL=anthropic/claude-3-haiku
EMBEDDING_MODEL=all-MiniLM-L6-v2
TOP_K_DENSE=5
TOP_K_SPARSE=5
TOP_K_FINAL=3
DOMAIN_SIMILARITY_THRESHOLD=0.28
CACHE_MAX_SIZE=1000
DEBUG=false
